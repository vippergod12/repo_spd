# ====== DATABASE (Neon Postgres serverless) ======
# Vào https://console.neon.tech tạo project miễn phí, copy "Pooled connection" string
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# ====== AUTH (Admin) ======
# Tối thiểu 32 ký tự ngẫu nhiên (vd: openssl rand -hex 32 — hoặc dùng https://generate-secret.now.sh/32)
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin@123

# ====== SITE / SEO ======
# Domain production (KHÔNG có dấu / cuối). Bắt buộc cho sitemap & metadata.
# Ví dụ: NEXT_PUBLIC_SITE_URL=https://repo-shop.vn
NEXT_PUBLIC_SITE_URL=

# ====== LIÊN HỆ — Zalo / Hotline / Email ======
# SĐT Zalo của shop (vd 0987654321) — dùng cho nút "Liên hệ Zalo"
NEXT_PUBLIC_ZALO_PHONE=0987654321
# (Tùy chọn) Link Zalo OA đầy đủ. Nếu set sẽ ghi đè ZALO_PHONE
# NEXT_PUBLIC_ZALO_URL=https://zalo.me/0987654321

NEXT_PUBLIC_HOTLINE=0987654321
NEXT_PUBLIC_EMAIL=support@repo-shop.vn

# ====== KÊNH GAMING — Telegram / Facebook / Discord ======
# Telegram là kênh chính của gamer; bắt buộc nên có
NEXT_PUBLIC_TELEGRAM_URL=https://t.me/repo_shop
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/repo.shop.pubg
# (Tùy chọn) Discord server — chỉ set nếu shop có Discord riêng
# NEXT_PUBLIC_DISCORD_URL=https://discord.gg/yourserver

# (Tùy chọn) Secret bảo vệ endpoint /api/_warm cho cron giữ Neon DB warm
# WARM_SECRET=another-random-string
